# ═════════════════════════════════════════════════════════════════════════════════
# ORB AUTO-TRADE SYSTEM - ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# ═════════════════════════════════════════════════════════════════════════════════
# BROKER API CREDENTIALS
# ═════════════════════════════════════════════════════════════════════════════════

# Kite Connect (Zerodha)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_REQUEST_TOKEN=your_request_token_here
KITE_ACCESS_TOKEN=your_access_token_here

# AliceBlue (Optional)
ALICEBLUE_USER_ID=your_user_id_here
ALICEBLUE_API_KEY=your_api_key_here
ALICEBLUE_API_SECRET=your_api_secret_here

# Shoonya (Optional)
SHOONYA_USER_ID=your_user_id_here
SHOONYA_PASSWORD=your_password_here
SHOONYA_API_KEY=your_api_key_here
SHOONYA_API_SECRET=your_api_secret_here

# ═════════════════════════════════════════════════════════════════════════════════
# TELEGRAM ALERTS (Optional)
# ═════════════════════════════════════════════════════════════════════════════════
# 1. Create bot via @BotFather on Telegram
# 2. Get bot token
# 3. Send message to your bot, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Find your chat_id in the response

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ═════════════════════════════════════════════════════════════════════════════════
# WEBHOOK SECURITY
# ═════════════════════════════════════════════════════════════════════════════════
# Set a secret key to verify webhook signatures
# Generate a random string: python -c "import secrets; print(secrets.token_hex(32))"

WEBHOOK_SECRET=your_secret_key_here

# ═════════════════════════════════════════════════════════════════════════════════
# TRADING FLAGS
# ═════════════════════════════════════════════════════════════════════════════════

# Set to true only after thorough paper trading
ENABLE_AUTO_TRADING=false

# Enable Telegram alerts
ENABLE_TELEGRAM_ALERTS=false
